{
  "sources": [
    {
      "name": "sample-fighter-profiles",
      "enabled": true,
      "format": "csv",
      "location": "app/data/sample_fighters.csv",
      "profile_mapping": {
        "name": "name",
        "weight_class": "weight_class",
        "age": "age",
        "height_cm": "height_cm",
        "reach_cm": "reach_cm",
        "wins": "wins",
        "losses": "losses",
        "ko_rate": "ko_rate",
        "submission_rate": "submission_rate",
        "takedown_accuracy": "takedown_accuracy",
        "takedown_defense": "takedown_defense",
        "strikes_landed_per_min": "strikes_landed_per_min",
        "strikes_absorbed_per_min": "strikes_absorbed_per_min"
      },
      "feature_fields": [
        "weight_class",
        "age",
        "height_cm",
        "reach_cm",
        "wins",
        "losses",
        "ko_rate",
        "submission_rate",
        "takedown_accuracy",
        "takedown_defense",
        "strikes_landed_per_min",
        "strikes_absorbed_per_min"
      ]
    },
    {
      "name": "supplemental-fighter-features",
      "enabled": true,
      "format": "csv",
      "location": "app/data/supplemental_fighter_features.csv",
      "profile_mapping": {
        "name": "name"
      },
      "extra_feature_mode": "all_unmapped"
    },
    {
      "name": "balldontlie-fighters-live",
      "enabled": true,
      "enabled_env": "BALLDONTLIE_API_KEY",
      "format": "json",
      "location": "https://api.balldontlie.io/mma/v1/fighters",
      "record_path": "data",
      "source_record_id_field": "id",
      "max_retries": 1,
      "retry_seconds": 65,
      "commit_interval": 100,
      "headers": {
        "Authorization": "${BALLDONTLIE_API_KEY}"
      },
      "pagination": {
        "type": "cursor",
        "cursor_param": "cursor",
        "per_page_param": "per_page",
        "per_page": 100,
        "next_cursor_path": "meta.next_cursor",
        "initial_cursor_env": "BALLDONTLIE_FIGHTERS_START_CURSOR",
        "max_pages": 500
      },
      "profile_mapping": {
        "name": "name",
        "weight_class": "weight_class.name",
        "wins": "record_wins",
        "losses": "record_losses"
      },
      "feature_fields": [
        "id",
        "active",
        "first_name",
        "last_name",
        "nickname",
        "nationality",
        "date_of_birth",
        "height_inches",
        "reach_inches",
        "weight_lbs",
        "stance",
        "record_wins",
        "record_losses",
        "record_draws",
        "record_no_contests",
        "weight_class.name",
        "weight_class.abbreviation",
        "weight_class.gender",
        "weight_class.weight_limit_lbs"
      ]
    },
    {
      "name": "the-odds-api-mma-current",
      "enabled": true,
      "enabled_env": "THE_ODDS_API_KEY",
      "format": "json",
      "location": "https://api.the-odds-api.com/v4/sports/mma_mixed_martial_arts/odds/?apiKey=${THE_ODDS_API_KEY}&regions=us&markets=h2h&oddsFormat=american",
      "profile_mapping": {
        "name": "home_team"
      },
      "extra_feature_mode": "all_unmapped"
    }
  ]
}
